cat > .gitignore << 'EOF'
# Dependencies
node_modules/
frontend/node_modules/
backend/node_modules/

# Environment files
.env
backend/.env
frontend/.env
*.env

# Build files
dist/
build/
frontend/dist/
backend/dist/

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE files
.vscode/
.idea/

# Upload folders
backend/uploads/
EOF